{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/reset-password",
      "dest": "/reset-password.html"
    },
    {
      "src": "/admin/dashboard",
      "dest": "/admin/dashboard.html"
    },
    {
      "src": "/consultor/dashboard",
      "dest": "/consultor/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}